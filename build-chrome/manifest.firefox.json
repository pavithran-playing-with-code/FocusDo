{
    "manifest_version": 2,
    "name": "FocusDo",
    "version": "1.2",
    "description": "Todo + Pomodoro productivity extension",
    "browser_action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "icon16.png",
            "48": "icon48.png",
            "128": "icon128.png"
        }
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "permissions": [
        "storage",
        "alarms",
        "notifications"
    ],
    "commands": {
        "_execute_browser_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+F",
                "mac": "Command+Shift+F"
            },
            "description": "Open FocusDo"
        }
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "focusdo@extension",
            "strict_min_version": "109.0"
        }
    }
}